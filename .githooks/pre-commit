#!/bin/sh
#
# 커밋 직전 스테이징된 PHP 파일에 PHP-CS-Fixer 스타일을 자동 적용합니다.
# (composer cs:fix 규칙 = .php-cs-fixer.dist.php)
#
# 활성화: 저장소 루트에서 `composer install` 을 실행하면 자동 등록됩니다.
#         (수동 등록: git config core.hooksPath .githooks)

# 스테이징된 .php 파일 목록 (삭제된 파일 제외)
STAGED_PHP="$(git diff --cached --name-only --diff-filter=ACMR | grep '\.php$')"

if [ -z "$STAGED_PHP" ]; then
    exit 0
fi

FIXER="./vendor/bin/php-cs-fixer"
if [ ! -x "$FIXER" ]; then
    echo "⚠ php-cs-fixer 를 찾을 수 없습니다. 'composer install' 후 다시 시도하세요. (이번 커밋은 통과)"
    exit 0
fi

echo "▶ PHP-CS-Fixer: 스테이징된 PHP 파일 스타일 점검·정규화 중..."

# 스테이징된 파일에만 적용
echo "$STAGED_PHP" | xargs "$FIXER" fix --config=.php-cs-fixer.dist.php --diff --quiet --path-mode=intersection
STATUS=$?

if [ $STATUS -ne 0 ]; then
    echo "✖ PHP-CS-Fixer 실행 중 오류가 발생했습니다. 커밋을 중단합니다."
    exit 1
fi

# 정규화로 변경된 파일을 다시 스테이징
echo "$STAGED_PHP" | xargs git add

echo "✔ PHP-CS-Fixer 적용 완료 — 정규화된 변경을 다시 스테이징했습니다."
exit 0
