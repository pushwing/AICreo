		-
			message: '#^Property App\\Controllers\\Front\\MyPageController\:\:\$userCouponModel is never read, only written\.$#'
			identifier: property.onlyWritten
			count: 1
			path: app/Controllers/Front/MyPageController.php

		-
			message: '#^Offset ''doc''\|''docx''\|''gif''\|''hwp''\|''jpeg''\|''jpg''\|''pdf''\|''png''\|''ppt''\|''pptx''\|''txt''\|''webp''\|''xls''\|''xlsx''\|''zip'' on array\{jpg\: array\{''image/jpeg''\}, jpeg\: array\{''image/jpeg''\}, png\: array\{''image/png''\}, gif\: array\{''image/gif''\}, webp\: array\{''image/webp''\}, pdf\: array\{''application/pdf''\}, doc\: array\{''application/msword''\}, docx\: array\{''application/vnd…''\}, \.\.\.\} on left side of \?\? always exists and is not nullable\.$#'
			identifier: nullCoalesce.offset
			count: 1
			path: app/Libraries/FileUploader.php

		-
			message: '#^Variable \$allowedMimes in empty\(\) always exists and is not falsy\.$#'
			identifier: empty.variable
			count: 1
			path: app/Libraries/FileUploader.php

		-
			message: '#^Left side of && is always true\.$#'
			identifier: booleanAnd.leftAlwaysTrue
			count: 1
			path: app/Models/BannerModel.php
