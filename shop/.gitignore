# CI4 기본 제외
/vendor/
.env
app/Config/App.php
writable/cache/*
writable/logs/*
writable/session/*
writable/tmp/*
!writable/cache/.gitkeep
!writable/logs/.gitkeep
!writable/session/.gitkeep
!writable/tmp/.gitkeep

# 업로드 파일 (실제 미디어는 제외, 폴더 구조만 유지)
public/uploads/*/*
!public/uploads/**/.gitkeep

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp

