# ─── PG 결제 연동 환경변수 ─────────────────────────────────────────────────────
# 사용하는 PG만 설정하면 됩니다. (미사용 PG는 주석 처리)
# 실제 .env 또는 서버 환경변수에 설정하세요. 이 파일을 커밋하지 마세요.

# ── 토스페이먼츠 ─────────────────────────────────────────────────────────────
# https://developers.tosspayments.com/my-account/api-keys
TOSS_CLIENT_KEY = test_ck_...
TOSS_SECRET_KEY = test_sk_...

# ── KG이니시스 ───────────────────────────────────────────────────────────────
# https://inilite.inicis.com (테스트: INIpayTest)
INICIS_MERCHANT_ID = INIpayTest
INICIS_SIGN_KEY    = SU5JTElURV9UUklQTEVERVNLRVlfVEVTVA==

# ── 나이스페이먼츠 ───────────────────────────────────────────────────────────
# https://npg.nicepay.co.kr/merchant/login.do
NICEPAY_CLIENT_ID  = S2_...
NICEPAY_SECRET_KEY = ...

# ── 카카오페이 ───────────────────────────────────────────────────────────────
# https://developers.kakaopay.com/docs/payment/online/ready
# 테스트 CID: TC0ONETIME
KAKAOPAY_SECRET_KEY = DEV...
KAKAOPAY_CID        = TC0ONETIME

# ── 네이버페이 ───────────────────────────────────────────────────────────────
# https://developer.pay.naver.com/docs/v2/api
NAVERPAY_CLIENT_ID     = ...
NAVERPAY_CLIENT_SECRET = ...
NAVERPAY_CHAIN_ID      = ...

# ── PAYCO ────────────────────────────────────────────────────────────────────
# https://developers.payco.com
PAYCO_SELLER_KEY = ...
PAYCO_SECRET_KEY = ...
