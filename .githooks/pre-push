#!/bin/sh
#
# push 직전 로컬에서 품질 게이트(composer ci = cs · analyse · test)를 실행합니다.
# CI에서 처음 실패를 만나 왕복하는 비용을 없애기 위한 훅입니다.
# (전체 실행 ~10초 수준)
#
# 활성화: 저장소 루트에서 `git config core.hooksPath .githooks`
# 건너뛰기: `git push --no-verify`

# composer 미설치 환경에서는 훅을 건너뛴다(이번 push는 통과).
if ! command -v composer >/dev/null 2>&1; then
    echo "⚠ composer 를 찾을 수 없어 품질 게이트를 건너뜁니다. (이번 push 는 통과)"
    exit 0
fi

# 의존성 미설치 시에도 통과시키되 안내한다.
if [ ! -d "./vendor" ]; then
    echo "⚠ vendor/ 가 없습니다. 'composer install' 후 다시 시도하세요. (이번 push 는 통과)"
    exit 0
fi

echo "▶ 품질 게이트 실행 중 (composer ci: cs · analyse · test)..."

composer ci
STATUS=$?

if [ $STATUS -ne 0 ]; then
    echo ""
    echo "✖ 품질 게이트 실패 — push 를 중단합니다."
    echo "  · 스타일 오류면: composer cs:fix"
    echo "  · 정적분석/테스트 오류면: 로그를 확인해 수정 후 다시 push"
    echo "  · 부득이하게 건너뛰려면: git push --no-verify"
    exit 1
fi

echo "✔ 품질 게이트 통과 — push 를 진행합니다."
exit 0
