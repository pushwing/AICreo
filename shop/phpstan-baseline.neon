			identifier: method.notFound
			count: 1
			path: app/Controllers/Admin/InquiryController.php

		-
			message: '#^Call to an undefined method App\\Models\\MediaModel\:\:countAll\(\)\.$#'
			identifier: method.notFound
			count: 1
			path: app/Controllers/Admin/MediaController.php

		-
			message: '#^Offset ''author_name'' on array\{id\: int, title\: string, is_notice\: int, is_secret\: int, views\: int, created_at\: string\|null, author_name\: string, board_name\: string, \.\.\.\} on left side of \?\? always exists and is not nullable\.$#'
			identifier: nullCoalesce.offset
			count: 1
			path: app/Controllers/Admin/PostController.php

		-
			message: '#^Offset ''board_name'' on array\{id\: int, title\: string, is_notice\: int, is_secret\: int, views\: int, created_at\: string\|null, author_name\: string, board_name\: string, \.\.\.\} on left side of \?\? always exists and is not nullable\.$#'
			identifier: nullCoalesce.offset
			count: 1
			path: app/Controllers/Admin/PostController.php

		-
			message: '#^Offset ''board_slug'' on array\{id\: int, title\: string, is_notice\: int, is_secret\: int, views\: int, created_at\: string\|null, author_name\: string, board_name\: string, \.\.\.\} on left side of \?\? always exists and is not nullable\.$#'
			identifier: nullCoalesce.offset
			count: 1
			path: app/Controllers/Admin/PostController.php

		-
			message: '#^Offset ''social_provider'' does not exist on list\<array\{id\: int, username\: string, email\: string, password\: string\|null, nickname\: string, role\: string, is_active\: int, last_login\: string\|null, \.\.\.\}\>\.$#'
			identifier: offsetAccess.notFound
