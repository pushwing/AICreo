# CI4 기본 제외
/vendor/
.env
writable/cache/*
writable/logs/*
writable/session/*
writable/tmp/*
writable/debugbar/*
!writable/cache/.gitkeep
!writable/logs/.gitkeep
!writable/session/.gitkeep
!writable/tmp/.gitkeep
!writable/debugbar/index.html

# 업로드 파일 (실제 미디어는 제외, 폴더 구조만 유지)
public/uploads/*/*
!public/uploads/**/.gitkeep

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp

# PHPStan (분석 임시 산출물)
/build/
/tmp/

# 로컬 전용 매뉴얼 PDF (배포용, 저장소 미포함)
docs/AiCreo-매뉴얼.pdf
